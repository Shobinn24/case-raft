FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string
DATABASE_URL=sqlite:///caseraft.db
# --- Clio OAuth ---
# Get these from the Clio developer dashboard: https://app.clio.com/settings/developer_applications
# IMPORTANT: CLIO_REDIRECT_URI must be BYTE-FOR-BYTE identical to the
# redirect URI registered on the Clio app (including scheme and trailing
# path). A mismatch shows up as a 404 on Clio's authorize page.
CLIO_CLIENT_ID=your-clio-client-id
CLIO_CLIENT_SECRET=your-clio-client-secret
CLIO_REDIRECT_URI=https://caseraft.com/auth/callback
